def max_subarray_sum(nums):
    max_so_far = nums[0]
    current_max = nums[0]
    
    for x in nums[1:]:
        current_max = max(x, current_max + x)
        max_so_far = max(max_so_far, current_max)
        
    return max_so_far

print(max_subarray_sum([-2, 1, -3, 4, -1, 2, 1, -5, 4]))

